{
  "info": {
    "name": "Algolia Ingestion API",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "Read-only endpoints for the Algolia Ingestion (Connectors) API. Covers authentications, destinations, sources, tasks, and transformations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.add({ key: 'X-Algolia-Application-Id', value: pm.environment.get('algoliaAppId') });",
          "pm.request.headers.add({ key: 'X-Algolia-API-Key', value: pm.environment.get('algoliaApiKey') });"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://data.us.algolia.com",
      "description": "Override via the active Postman environment. Change region as needed (us, eu, de, au)."
    }
  ],
  "item": [
    {
      "name": "Authentications",
      "item": [
        {
          "name": "List Authentications",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/1/authentications",
              "host": ["{{baseUrl}}"],
              "path": ["1", "authentications"],
              "query": [
                { "key": "itemsPerPage", "value": "20", "disabled": true, "description": "Number of items per page." },
                { "key": "page", "value": "1", "disabled": true, "description": "Page number (1-based)." },
                { "key": "type", "value": "basic", "disabled": true, "description": "Filter by authentication type. Repeat this key for multiple values." },
                { "key": "platform", "value": "bigcommerce", "disabled": true, "description": "Filter by platform. Repeat this key for multiple values." },
                { "key": "sort", "value": "createdAt", "disabled": true, "description": "Field to sort by." },
                { "key": "order", "value": "desc", "disabled": true, "description": "Sort direction: asc or desc." }
              ]
            },
            "description": "Retrieve a paginated list of authentications. Enable query params as needed."
          }
        },
        {
          "name": "Get Authentication",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/1/authentications/:authenticationID",
              "host": ["{{baseUrl}}"],
              "path": ["1", "authentications", ":authenticationID"],
              "variable": [
                {
                  "key": "authenticationID",
                  "value": "{{authenticationID}}",
                  "description": "Set authenticationID in your Postman environment."
                }
              ]
            },
            "description": "Retrieve a single authentication by ID. Set `authenticationID` in the active environment."
          }
        }
      ]
    },
    {
